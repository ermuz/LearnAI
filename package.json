{
  "name": "@ermuz/learn-ai",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@ermuz/eslint-config": "workspace:*",
    "@ermuz/tsconfig": "workspace:*",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.14.2",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@ermuz/node-shared": "workspace:*",
    "@langchain/classic": "^1.0.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.12",
    "@langchain/tavily": "^1.2.0",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@zilliz/milvus2-sdk-node": "^2.6.10",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "js-tiktoken": "^1.0.21",
    "langchain": "^1.2.35",
    "pdf-parse": "^1",
    "tsx": "^4.19.2",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  }
}
